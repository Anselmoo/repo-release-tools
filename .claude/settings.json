{
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/rrt_ux_guard.py",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/check_push_coverage.py",
            "timeout": 900
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit|str_replace_based_edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/rrt_ux_write_guard.py",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/refresh_coverage_baseline.py",
            "timeout": 60
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/completeness_guard.py",
            "timeout": 60
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/drift_guard.py",
            "timeout": 120
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/coverage_non_regression.py",
            "timeout": 60
          }
        ]
      }
    ]
  }
}

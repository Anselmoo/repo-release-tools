---
/**
 * Docs site header. Reproduces docs/_layouts/default.html's site-header:
 * hexagon logo glyph + wordmark on the left, terminal-button nav links on
 * the right. Pass content into the `right` slot for a search box / theme
 * toggle (commonly Starlight's native search + theme toggle, re-skinned,
 * per the design-system.mdx visual-reference notes).
 *
 * Ported from components/navigation/Header.jsx (Reto design system mirror).
 */
interface NavLink {
  label: string;
  href?: string;
  active?: boolean;
}

interface Props {
  title?: string;
  href?: string;
  links?: NavLink[];
  logo?: string;
}

const { title = "repo-release-tools", href = "#", links = [], logo = "⬡" } = Astro.props as Props;
---

<header class="reto-header">
  <a href={href} class="reto-header__brand">
    <span class="reto-header__logo" aria-hidden="true">{logo}</span>
    {title}
  </a>

  <div class="reto-header__bar">
    <nav class="reto-header__links">
      {links.map((link) => (
        <a
          href={link.href || "#"}
          class={link.active ? "reto-header__link reto-header__link--active" : "reto-header__link"}
        >
          {link.label}
        </a>
      ))}
    </nav>
    <div class="reto-header__utility">
      <slot name="right" />
    </div>
  </div>
</header>

<style>
  .reto-header {
    padding: 1.25rem 2rem;
    border-bottom: 2px solid var(--reto-border);
    background: var(--reto-bg-elevated);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .reto-header__brand {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    color: var(--reto-accent);
    text-decoration: none;
    font-family: var(--reto-font-display);
    font-size: 1.1rem;
    text-transform: uppercase;
    letter-spacing: var(--tracking-display);
    text-shadow: var(--reto-phosphor-glow);
    flex-shrink: 0;
  }

  .reto-header__logo {
    color: var(--reto-accent-strong);
    font-size: 1.4em;
  }

  /* Single row holding both the primary nav links and the utility controls
     (search / GitHub / theme toggle) — the two groups used to share one
     wrapping flex container with no separation between them, so at normal
     desktop widths they'd overflow onto their own line below the links,
     collapsing the header into 3 stacked rows instead of 1. */
  .reto-header__bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex: 1 1 auto;
    min-width: 0;
    gap: 1rem;
  }

  .reto-header__links {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    min-width: 0;
  }

  .reto-header__utility {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  @media (max-width: 900px) {
    .reto-header {
      flex-wrap: wrap;
    }

    .reto-header__bar {
      flex-basis: 100%;
      justify-content: flex-start;
      flex-wrap: wrap;
    }
  }

  @media (max-width: 640px) {
    .reto-header__bar {
      flex-direction: column;
      align-items: flex-start;
    }

    .reto-header__utility {
      flex-basis: 100%;
    }
  }

  .reto-header__link {
    display: inline-block;
    padding: 0.5rem 1.2rem;
    font-family: var(--reto-font-display);
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    color: var(--reto-accent);
    background: transparent;
    border: 1px solid var(--reto-border);
    text-decoration: none;
    transition: all 0.1s ease;
  }

  .reto-header__link:hover {
    background: var(--reto-accent);
    color: var(--reto-bg);
    border-color: var(--reto-accent);
    box-shadow: var(--reto-phosphor-glow);
    transform: scale(1.05);
  }

  .reto-header__link--active {
    color: var(--reto-bg);
    background: var(--reto-accent);
    border-color: var(--reto-accent);
    text-shadow: var(--reto-phosphor-glow);
  }
</style>

---
/**
 * Admonition callout — same visual language as the source's blockquote
 * (accent-bordered box on code-bg), with a tone-colored left bar + label.
 * `title` overrides the default all-caps label.
 *
 * Ported from components/feedback/Callout.jsx (Reto design system mirror).
 * Tone colors are resolved to one CSS class per tone (`.reto-callout--<tone>`)
 * in the scoped <style> block below, matching the class-per-variant pattern
 * used by Button.astro/StatusPanel.astro — frontmatter only picks the class
 * name, no inline style for tone-driven values.
 */
interface Props {
  tone?: "note" | "tip" | "warning" | "danger";
  title?: string;
}

const TONE_META: Record<string, { label: string; glyph: string }> = {
  note: { label: "NOTE", glyph: "»" },
  tip: { label: "TIP", glyph: "★" },
  warning: { label: "WARNING", glyph: "▲" },
  danger: { label: "DANGER", glyph: "✕" },
};

const { tone = "note", title } = Astro.props as Props;

const t = TONE_META[tone] || TONE_META.note;
---

<div class={`reto-callout reto-callout--${tone}`}>
  <div class="reto-callout__label">
    <span aria-hidden="true">{t.glyph}</span>
    {title || t.label}
  </div>
  <div class="reto-callout__body">
    <slot />
  </div>
</div>

<style>
  .reto-callout {
    border: 1px solid var(--reto-border);
    background: var(--reto-code-bg);
    border-left: 8px solid var(--reto-accent-strong);
    padding: 1rem 1.5rem;
    margin: 1.5rem 0;
  }

  .reto-callout__label {
    font-family: var(--reto-font-display);
    font-size: 0.78rem;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    margin-bottom: 0.4rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .reto-callout__body {
    color: var(--reto-text-soft);
    font-family: var(--reto-font-body);
    line-height: var(--leading-body);
  }

  /* Tones — border-left + label color per tone (mirrors Callout.jsx's TONE map) */
  .reto-callout--note {
    border-left-color: var(--reto-accent-strong);
  }
  .reto-callout--note .reto-callout__label {
    color: var(--reto-accent-strong);
  }

  .reto-callout--tip {
    border-left-color: var(--reto-success-strong);
  }
  .reto-callout--tip .reto-callout__label {
    color: var(--reto-success-strong);
  }

  .reto-callout--warning {
    border-left-color: var(--reto-accent-strong);
  }
  .reto-callout--warning .reto-callout__label {
    color: var(--reto-accent-strong);
  }

  .reto-callout--danger {
    border-left-color: var(--reto-danger-strong);
  }
  .reto-callout--danger .reto-callout__label {
    color: var(--reto-danger-strong);
  }
</style>
